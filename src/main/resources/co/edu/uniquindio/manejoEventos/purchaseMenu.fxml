<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="606.0" prefWidth="792.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="co.edu.uniquindio.manejoEventos.viewController.PurchaseView">
    <children>
        <Button layoutX="14.0" layoutY="14.0" mnemonicParsing="false" onAction="#backAction" styleClass="button-outlined" text="← Back" />
        
        <Text fx:id="eventNameText" layoutX="146.0" layoutY="35.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Event Name" textAlignment="CENTER" wrappingWidth="500.0">
            <font>
                <Font size="24.0" />
            </font>
        </Text>
        
        <Label layoutX="30.0" layoutY="70.0" text="Seleccionar Zona:" />
        <ChoiceBox fx:id="zoneChoiceBox" layoutX="140.0" layoutY="65.0" prefWidth="200.0" />

        <Label layoutX="610.0" layoutY="128.0" text="Seleccionar Sillas" />
        <ScrollPane fx:id="chairsScrollPane" layoutX="76.0" layoutY="155.0" prefHeight="250.0" prefWidth="640.0">
            <content>
                <GridPane fx:id="chairsGrid" alignment="CENTER" hgap="10" vgap="10">
                    <!-- Chairs will be dynamically added here -->
                </GridPane>
            </content>
        </ScrollPane>
        <Label fx:id="noChairsLabel" layoutX="200.0" layoutY="240.0" style="-fx-font-size: 18px; -fx-text-fill: #888888; -fx-font-style: italic;" text="No aplica para esta zona" visible="false" />

        <Label layoutX="30.0" layoutY="424.0" style="-fx-font-weight: bold;" text="Servicios Adicionales:" />
        <CheckBox fx:id="cateringCheck" layoutX="35.0" layoutY="458.0" onAction="#updateTotalCost" text="Catering ($50,000)" />
        <CheckBox fx:id="insuranceCheck" layoutX="244.0" layoutY="458.0" onAction="#updateTotalCost" text="Seguro ($15,000)" />
        <CheckBox fx:id="merchandisingCheck" layoutX="432.0" layoutY="458.0" onAction="#updateTotalCost" text="Merchandising ($25,000)" />
        <CheckBox fx:id="parkingCheck" layoutX="36.0" layoutY="496.0" onAction="#updateTotalCost" text="Parqueadero ($10,000)" />
        <CheckBox fx:id="preferentialCheck" layoutX="244.0" layoutY="496.0" onAction="#updateTotalCost" text="Acceso Preferencial ($30,000)" />

        <Label layoutX="32.0" layoutY="533.0" text="Método de Pago:" />
        <ChoiceBox fx:id="paymentTypeChoiceBox" layoutX="140.0" layoutY="529.0" prefWidth="150.0" />

        <Text layoutX="514.0" layoutY="560.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Total: $" />
        <Text fx:id="totalCostText" layoutX="564.0" layoutY="561.0" strokeType="OUTSIDE" strokeWidth="0.0" text="0.0">
            <font>
                <Font name="System Bold" size="16.0" />
            </font>
        </Text>

        <Button fx:id="payButton" layoutX="657.0" layoutY="535.0" mnemonicParsing="false" onAction="#payAction" prefHeight="40.0" prefWidth="100.0" text="Guardar" />
    </children>
</AnchorPane>
